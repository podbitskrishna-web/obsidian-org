# Obsidian Labs — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — add it to .gitignore.

# ══════════════════════════════════════════════
# GEMINI API KEY (for Orion AI chatbot)
# ══════════════════════════════════════════════
# Get a free key at: https://aistudio.google.com/app/apikey
# Free tier supports gemini-2.0-flash (fast, high quality).
# Paid tier supports gemini-2.5-pro (highest quality).
GEMINI_API_KEY=

# ══════════════════════════════════════════════
# (Optional) Override Gemini model
# Default: gemini-2.0-flash
# ══════════════════════════════════════════════
# GEMINI_MODEL=gemini-2.5-pro
